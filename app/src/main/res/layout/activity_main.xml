<?xml version="1.0" encoding="utf-8"?>
<!-- activity_main.xml -->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal"
    android:background="#F4F6F9">

    <!-- Titre principal -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏡 Taxe d'Habitation"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#1A237E"
        android:layout_marginBottom="24dp" />

    <!-- Champ : superficie du logement -->
    <EditText
        android:id="@+id/et_superficie"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Superficie du logement (m²)"
        android:inputType="numberDecimal"
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Champ : nombre de chambres -->
    <EditText
        android:id="@+id/et_chambres"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Nombre de chambres"
        android:inputType="number"
        android:background="@android:drawable/edit_text"
        android:padding="12dp"
        android:layout_marginBottom="16dp" />

    <!-- Case à cocher : jardin privé -->
    <CheckBox
        android:id="@+id/cb_jardin"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Jardin privé inclus"
        android:textColor="#37474F"
        android:layout_marginBottom="24dp" />

    <!-- Bouton de calcul -->
    <Button
        android:id="@+id/btn_estimer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Estimer la taxe"
        android:backgroundTint="#1A237E"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:padding="14dp" />

    <!-- Ligne 1 : Taxe de base -->
    <TextView
        android:id="@+id/tv_base"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#37474F"
        android:layout_marginTop="24dp" />

    <!-- Ligne 2 : Supplément -->
    <TextView
        android:id="@+id/tv_supplement"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textColor="#37474F"
        android:layout_marginTop="6dp" />

    <!-- Ligne 3 : Total -->
    <TextView
        android:id="@+id/tv_montant"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginTop="6dp" />

</LinearLayout>